{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python ./scripts/mcp_server.py rebuild --quiet"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ./scripts/mcp_server.py rebuild --quiet"
          }
        ]
      }
    ]
  }
}
